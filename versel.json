{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "cleanDistDir": true
      }
    }
  ],
  "routes": [
    {
      "src": "/.*",
      "dest": "/build/index.html",
      "methods": ["GET"]
    },
    {
      "src": "/static/.*",
      "dest": "/build/static/$1"
    }
  ]
}